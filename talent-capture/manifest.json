{
  "manifest_version": 3,
  "name": "Fanny 达人抓取",
  "description": "Capture creator profile data from NoxInfluencer, FastMoss, TikTok, Instagram, and YouTube into the FANY talent database.",
  "version": "0.4.12",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Fanny 达人抓取",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://*.tiktok.com/*",
        "https://www.instagram.com/*",
        "https://*.instagram.com/*",
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.facebook.com/*",
        "https://*.facebook.com/*",
        "https://cn.noxinfluencer.com/*",
        "https://www.noxinfluencer.com/*",
        "https://*.noxinfluencer.com/*",
        "https://www.fastmoss.com/*",
        "https://*.fastmoss.com/*"
      ],
      "js": ["content-scripts/extractors.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "permissions": [
    "activeTab",
    "sidePanel",
    "tabs",
    "scripting",
    "storage"
  ],
  "options_page": "options.html"
}
